#!/usr/bin/env bash
# Pre-commit hook: run Prettier --write on staged files and re-stage them.
# Wired up via `git config core.hooksPath .githooks` (see prepare script in
# package.json). Skips gracefully if pnpm is unavailable.

set -euo pipefail

if ! command -v pnpm >/dev/null 2>&1; then
  echo "pre-commit: pnpm not on PATH, skipping format check"
  exit 0
fi

STAGED=$(git diff --cached --name-only --diff-filter=ACM | \
  grep -E '\.(ts|tsx|js|jsx|mjs|cjs|json|md|mdx|css|scss|html|yml|yaml)$' || \
  true)

if [ -z "${STAGED}" ]; then
  exit 0
fi

echo "pre-commit: running prettier on staged files"

# shellcheck disable=SC2086
pnpm exec prettier --write ${STAGED}

# Re-stage any file prettier modified.
git add -- ${STAGED}
