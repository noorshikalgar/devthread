{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Taskline",
  "version": "0.1.0",
  "identifier": "dev.taskline.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev:tauri-web",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Taskline",
        "width": 1320,
        "height": 860,
        "minWidth": 560,
        "minHeight": 480,
        "decorations": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: data: http: https:",
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPDATA/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "DeveloperTool",
    "shortDescription": "Thread-first developer work journal",
    "longDescription": "Taskline keeps a chronological journal of progress, findings, blockers, and decisions for each task — all stored locally on your machine.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
